# OpenAI Responses API — Codex Passthrough
#
# Copy to .env, set values, then source:
#   cp .env.example .env && chmod 600 .env
#   set -a && . ./.env && set +a

# OpenAI project API key. Never committed or logged.
OPENAI_API_KEY=

# Upstream model name. Must be accessible with the above key.
OPENAI_MODEL=gpt-4.1-mini

# Absolute path to the Praxis binary. Omit if praxis is on PATH.
PRAXIS_BIN=

# Local listener port for Praxis.
PRAXIS_PORT=18480

# Client-facing model alias sent by Codex and curl.
CODEX_CLIENT_MODEL=codex-openai-demo

# Optional Codex sandbox override. The default is workspace-write. Use
# danger-full-access only in an externally isolated container when bwrap
# cannot create a workspace sandbox.
# CODEX_SANDBOX_MODE=workspace-write
